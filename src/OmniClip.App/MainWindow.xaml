<Window x:Class="OmniClip.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OmniClip - 剪贴板管理器"
        Width="820" Height="600"
        Background="White"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="FlatButton" TargetType="Button">
            <Setter Property="Background" Value="#F7F7F9"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#EBF1FF"/>
                                <Setter Property="BorderBrush" Value="#4F6EF7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource FlatButton}">
            <Setter Property="Background" Value="#4F6EF7"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#4F6EF7"/>
        </Style>

        <Style x:Key="SidebarListBox" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Hidden"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Hidden"/>
        </Style>

        <Style x:Key="MainListBox" TargetType="ListBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Hidden"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Hidden"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="170"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="250"/>
        </Grid.ColumnDefinitions>

        <!-- Left: Tag Filter -->
        <Border Grid.Column="0" Background="#F7F7F9" BorderBrush="#E5E5E5" BorderThickness="0,0,1,0">
            <StackPanel>
                <TextBlock Text="分类筛选" FontSize="11" Foreground="#888"
                           FontWeight="SemiBold" Margin="16,14,0,10"/>

                <ListBox x:Name="TagFilterList" Style="{StaticResource SidebarListBox}"
                         SelectionChanged="TagFilterList_SelectionChanged">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="16,8"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Border"
                                                Background="{TemplateBinding Background}"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="White"/>
                                                <Setter TargetName="Border" Property="BorderBrush" Value="#4F6EF7"/>
                                                <Setter TargetName="Border" Property="BorderThickness" Value="3,0,0,0"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="#EFEFF3"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Icon}" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding Name}" Foreground="#333"/>
                                <TextBlock Text="{Binding Count, StringFormat=' {0}'}"
                                           Foreground="#BBB" FontSize="10" Margin="4,0,0,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </Border>

        <!-- Center: Entry List -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Search bar -->
            <Border Grid.Row="0" Padding="12,10" Background="White"
                    BorderBrush="#EBEBEB" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#F5F5F7" BorderThickness="0"
                            Padding="8,5" Margin="0,0,10,0">
                        <TextBox x:Name="MainSearchBox"
                                 Background="Transparent" Foreground="#1A1A1A"
                                 BorderThickness="0" FontSize="13"
                                 CaretBrush="#4F6EF7"
                                 TextChanged="MainSearchBox_TextChanged"/>
                    </Border>
                    <ComboBox Grid.Column="1" x:Name="SortCombo"
                              Background="#F5F5F7" Foreground="#333"
                              BorderThickness="0" FontSize="11"
                              SelectedIndex="0">
                        <ComboBoxItem Content="时间降序"/>
                        <ComboBoxItem Content="相关性"/>
                    </ComboBox>
                </Grid>
            </Border>

            <!-- Entry list -->
            <ListBox Grid.Row="1" x:Name="EntryListMain"
                     Style="{StaticResource MainListBox}"
                     SelectionChanged="EntryListMain_SelectionChanged">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="16,10"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="#F2F2F2"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Border"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="#F0F4FF"/>
                                            <Setter Property="BorderBrush" Value="#4F6EF7"/>
                                            <Setter TargetName="Border" Property="BorderThickness" Value="3,0,0,0"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="#FAFAFC"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                <TextBlock Text="{Binding CreatedAt, StringFormat='{}{0:HH:mm}'}"
                                           FontSize="10" Foreground="#999"/>
                                <TextBlock Text=" · " FontSize="10" Foreground="#CCC"/>
                                <TextBlock Text="{Binding SourceApp}" FontSize="10" Foreground="#999"/>
                            </StackPanel>
                            <TextBlock Text="{Binding PlainText}" FontSize="13"
                                       Foreground="#1A1A1A"
                                       TextTrimming="CharacterEllipsis" MaxHeight="38"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <!-- Right: Preview -->
        <Border Grid.Column="2" Background="#F7F7F9" BorderBrush="#E5E5E5" BorderThickness="1,0,0,0"
                Padding="16">
            <StackPanel>
                <TextBlock Text="预览" FontSize="11" Foreground="#888"
                           FontWeight="SemiBold" Margin="0,0,0,10"/>

                <ScrollViewer VerticalScrollBarVisibility="Hidden" MaxHeight="280">
                    <TextBlock x:Name="PreviewText" Text="选择一条记录查看预览"
                               Foreground="#333" FontSize="12" TextWrapping="Wrap"
                               LineHeight="20"/>
                </ScrollViewer>

                <Border Background="#F0F0F4" Padding="10" Margin="0,12,0,0">
                    <TextBlock x:Name="MetaInfo" FontSize="10" Foreground="#888"
                               TextWrapping="Wrap" LineHeight="16"/>
                </Border>

                <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                    <Button Content="复制" Style="{StaticResource AccentButton}" Click="CopyEntry_Click"
                            Margin="0,0,8,0"/>
                    <Button Content="收藏" Style="{StaticResource FlatButton}" Click="FavoriteEntry_Click"
                            Margin="0,0,8,0"/>
                    <Button Content="删除" Style="{StaticResource FlatButton}" Click="DeleteEntry_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
