<Window x:Class="OmniClip.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:OmniClip.App.Converters"
        Title="OmniClip - 剪贴板管理器"
        Width="1020" Height="640"
        MinWidth="800" MinHeight="500"
        Background="#FCF9F8"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <conv:RelativeTimeConverter x:Key="RelTime"/>
        <conv:ContentTypeToColorConverter x:Key="TypeToColor"/>
        <conv:ContentTypeToIconConverter x:Key="TypeToIcon"/>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="256"/>
            <ColumnDefinition Width="384"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Column 1: Sidebar -->
        <Border Grid.Column="0" Background="#F6F3F2"
                BorderBrush="#E5E2E1" BorderThickness="0,0,1,0">
            <StackPanel>
                <TextBlock Text="OmniClip" FontSize="20" FontWeight="SemiBold"
                           Foreground="#005FAA" Margin="16,20,16,8"/>
                <TextBlock Text="Professional Clipboard" FontSize="11"
                           Foreground="#717783" Margin="16,0,16,16"/>

                <ListBox x:Name="SidebarNav" BorderThickness="0" Background="Transparent"
                         SelectionChanged="SidebarNav_SelectionChanged">
                    <ListBoxItem Padding="12,10" Margin="8,1" IsSelected="True" Tag="all">
                        <TextBlock Text="All Items" FontSize="14"/>
                    </ListBoxItem>
                    <ListBoxItem Padding="12,10" Margin="8,1" Tag="code">
                        <TextBlock Text="Code Snippets" FontSize="14"/>
                    </ListBoxItem>
                    <ListBoxItem Padding="12,10" Margin="8,1" Tag="url">
                        <TextBlock Text="Web Links" FontSize="14"/>
                    </ListBoxItem>
                    <ListBoxItem Padding="12,10" Margin="8,1" Tag="text">
                        <TextBlock Text="Plain Text" FontSize="14"/>
                    </ListBoxItem>
                    <ListBoxItem Padding="12,10" Margin="8,1" Tag="image">
                        <TextBlock Text="Images" FontSize="14"/>
                    </ListBoxItem>
                    <ListBoxItem Padding="12,10" Margin="8,1" Tag="file">
                        <TextBlock Text="Files" FontSize="14"/>
                    </ListBoxItem>
                </ListBox>
            </StackPanel>
        </Border>

        <!-- Column 2: Feed -->
        <Grid Grid.Column="1" Background="White">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Padding="24,16" BorderBrush="#E5E2E1" BorderThickness="0,0,0,1">
                <TextBox x:Name="MainSearchBox" FontSize="13"
                         TextChanged="MainSearchBox_TextChanged"/>
            </Border>

            <ListBox Grid.Row="1" x:Name="EntryListMain" BorderThickness="0"
                     SelectionChanged="EntryListMain_SelectionChanged"
                     ScrollViewer.VerticalScrollBarVisibility="Hidden"
                     Margin="8,12,8,8">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,0,0,8">
                            <TextBlock Text="{Binding SourceApp}" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding PlainText}" FontSize="13"
                                       TextTrimming="CharacterEllipsis" MaxHeight="36"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <!-- Column 3: Preview -->
        <Border Grid.Column="2" Background="#F6F3F2" Padding="16">
            <TextBlock x:Name="PreviewText" Text="Select an item"
                       FontSize="14" TextWrapping="Wrap"/>
        </Border>
    </Grid>
</Window>
