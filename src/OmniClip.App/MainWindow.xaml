<Window x:Class="OmniClip.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:OmniClip.App.Converters"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
        Title="OmniClip"
        Width="1280" Height="760"
        MinWidth="1020" MinHeight="620"
        Background="#FCF9F8"
        FontFamily="Inter, Segoe UI Variable Display, Segoe UI, PingFang SC, HarmonyOS Sans SC, Microsoft YaHei"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <WindowChrome.WindowChrome>
        <shell:WindowChrome
            CaptionHeight="0"
            CornerRadius="8"
            GlassFrameThickness="0"
            ResizeBorderThickness="4"
            UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Icon>
        <BitmapImage UriSource="pack://application:,,,/Resources/logo.png"/>
    </Window.Icon>

    <Window.Resources>
        <conv:RelativeTimeConverter x:Key="RelTime"/>
        <conv:ContentTypeToColorConverter x:Key="TypeToColor"/>
        <conv:ContentTypeToIconConverter x:Key="TypeToIcon"/>
        <conv:FilePathToImageConverter x:Key="FilePathToImage"/>
        <conv:FileNameToIconConverter x:Key="FileIcon"/>

        <!-- Reference design tokens from docs/UI参考/DESIGN.md -->
        <SolidColorBrush x:Key="BackgroundBrush" Color="#FCF9F8"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FCF9F8"/>
        <SolidColorBrush x:Key="SurfaceLowestBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SurfaceLowBrush" Color="#F6F3F2"/>
        <SolidColorBrush x:Key="SurfaceContainerBrush" Color="#F0EDED"/>
        <SolidColorBrush x:Key="SurfaceHighBrush" Color="#EAE7E7"/>
        <SolidColorBrush x:Key="SurfaceVariantBrush" Color="#E5E2E1"/>
        <SolidColorBrush x:Key="OnSurfaceBrush" Color="#1B1B1B"/>
        <SolidColorBrush x:Key="OnSurfaceVariantBrush" Color="#404752"/>
        <SolidColorBrush x:Key="OutlineBrush" Color="#717783"/>
        <SolidColorBrush x:Key="OutlineVariantBrush" Color="#C0C7D4"/>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#005FAA"/>
        <SolidColorBrush x:Key="PrimaryContainerBrush" Color="#0078D4"/>
        <SolidColorBrush x:Key="SecondaryContainerBrush" Color="#DCDDDD"/>
        <SolidColorBrush x:Key="OnSecondaryContainerBrush" Color="#5F6161"/>

        <DropShadowEffect x:Key="PreviewShadow" BlurRadius="60" ShadowDepth="16" Opacity="0.12" Color="#000000"/>
        <DropShadowEffect x:Key="CardHoverShadow" BlurRadius="16" ShadowDepth="4" Opacity="0.10" Color="#000000"/>

        <Style x:Key="CardActionBtn" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Foreground" Value="#A0A7B4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="Transparent" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#EAE7E7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>

        <Style x:Key="NavItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="20,0,20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#202734"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="NavBorder"
                                Height="44"
                                Background="Transparent"
                                CornerRadius="7"
                                Padding="20,0">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="NavBorder" Property="Background" Value="#0078D4"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="NavBorder" Property="Background" Value="#EAE7E7"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PillButton" TargetType="Button">
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#1B1B1B"/>
            <Setter Property="Background" Value="#F0EDED"/>
            <Setter Property="BorderBrush" Value="#D9DEE7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#E5E2E1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryActionButton" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="MinWidth" Value="130"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Background" Value="#005FAA"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ActionBorder" Background="{TemplateBinding Background}" CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ActionBorder" Property="Background" Value="#0060AB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryActionButton" TargetType="Button" BasedOn="{StaticResource PrimaryActionButton}">
            <Setter Property="MinWidth" Value="80"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#1B1B1B"/>
            <Setter Property="BorderBrush" Value="#D9DEE7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ActionBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ActionBorder" Property="Background" Value="#F6F3F2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="CardBorder"
                                Background="#FCF9F8"
                                BorderBrush="#E7E9EE"
                                BorderThickness="1.5"
                                CornerRadius="8"
                                Padding="0">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CardBorder" Property="Background" Value="White"/>
                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="#005FAA"/>
                                <Setter TargetName="CardBorder" Property="Effect" Value="{StaticResource CardHoverShadow}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="CardBorder" Property="Background" Value="#FCF9F8"/>
                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="#005FAA"/>
                                <Setter TargetName="CardBorder" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionHeader" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="IsHitTestVisible" Value="False"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="SectionTemplate">
            <TextBlock Text="{Binding Label}"
                       Margin="10,22,0,12"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="#005FAA"/>
        </DataTemplate>

        <DataTemplate x:Key="CardTemplate">
            <Border MinHeight="68" Padding="18,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Style="{StaticResource IconText}"
                               Text="{Binding ContentType, Converter={StaticResource TypeToIcon}}"
                               Foreground="{Binding ContentType, Converter={StaticResource TypeToColor}}"
                               VerticalAlignment="Top"
                               Width="24"
                               TextAlignment="Center"
                               Margin="0,2,0,0"/>

                    <StackPanel Grid.Column="1" Margin="16,0,0,0">
                        <TextBlock Text="{Binding SourceApp}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="#1B1B1B"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding PlainText}"
                                   Margin="0,5,0,0"
                                   FontSize="14"
                                   Foreground="#202734"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="Wrap"
                                   MaxHeight="42"/>
                    </StackPanel>

                    <TextBlock Grid.Column="2"
                               Text="{Binding CreatedAt, Converter={StaticResource RelTime}}"
                               Margin="14,4,0,0"
                               VerticalAlignment="Top"
                               FontSize="11"
                               Foreground="#717783"/>

                    <Button Content="&#xE8C8;" Style="{StaticResource CardActionBtn}"
                            Grid.Column="2" Grid.ColumnSpan="2"
                            HorizontalAlignment="Right" VerticalAlignment="Bottom"
                            ToolTip="Copy"
                            Click="CardCopy_Click" Tag="{Binding}"/>
                    <Button Content="&#xE718;" Style="{StaticResource CardActionBtn}"
                            Grid.Column="2" Grid.ColumnSpan="2"
                            HorizontalAlignment="Right" VerticalAlignment="Bottom"
                            Margin="0,0,24,0"
                            ToolTip="Pin"
                            Click="CardPin_Click" Tag="{Binding}"/>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="ImageCardTemplate">
            <Border MinHeight="68" Padding="18,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Style="{StaticResource IconText}"
                               Text="{Binding ContentType, Converter={StaticResource TypeToIcon}}"
                               Foreground="{Binding ContentType, Converter={StaticResource TypeToColor}}"
                               VerticalAlignment="Top"
                               Width="24"
                               TextAlignment="Center"
                               Margin="0,2,0,0"/>

                    <StackPanel Grid.Column="1" Margin="16,0,0,0">
                        <TextBlock Text="{Binding SourceApp}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="#1B1B1B"
                                   TextTrimming="CharacterEllipsis"/>
                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                            <Border Width="64" Height="40"
                                    Background="#F0EDED"
                                    CornerRadius="6"
                                    BorderBrush="#D9DEE7"
                                    BorderThickness="1"
                                    ClipToBounds="True">
                                <Image Source="{Binding FilePath, Converter={StaticResource FilePathToImage}}"
                                       Stretch="UniformToFill"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="{Binding FileName}"
                                       Margin="10,0,0,0"
                                       FontSize="13"
                                       Foreground="#404752"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Grid.Column="2"
                               Text="{Binding CreatedAt, Converter={StaticResource RelTime}}"
                               Margin="14,4,0,0"
                               VerticalAlignment="Top"
                               FontSize="11"
                               Foreground="#717783"/>
                    <Button Content="&#xE8C8;" Style="{StaticResource CardActionBtn}"
                            Grid.Column="2" Grid.ColumnSpan="2"
                            HorizontalAlignment="Right" VerticalAlignment="Bottom"
                            ToolTip="Copy"
                            Click="CardCopy_Click" Tag="{Binding}"/>
                    <Button Content="&#xE718;" Style="{StaticResource CardActionBtn}"
                            Grid.Column="2" Grid.ColumnSpan="2"
                            HorizontalAlignment="Right" VerticalAlignment="Bottom"
                            Margin="0,0,24,0"
                            ToolTip="Pin"
                            Click="CardPin_Click" Tag="{Binding}"/>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="FileCardTemplate">
            <Border MinHeight="68" Padding="18,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Style="{StaticResource IconText}"
                               Text="{Binding FileName, Converter={StaticResource FileIcon}}"
                               Foreground="{Binding ContentType, Converter={StaticResource TypeToColor}}"
                               VerticalAlignment="Top"
                               Width="24"
                               TextAlignment="Center"
                               Margin="0,2,0,0"/>

                    <StackPanel Grid.Column="1" Margin="16,0,0,0">
                        <TextBlock Text="{Binding SourceApp}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="#1B1B1B"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding FileName}"
                                   Margin="0,5,0,0"
                                   FontSize="14"
                                   Foreground="#202734"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="NoWrap"/>
                    </StackPanel>

                    <TextBlock Grid.Column="2"
                               Text="{Binding CreatedAt, Converter={StaticResource RelTime}}"
                               Margin="14,4,0,0"
                               VerticalAlignment="Top"
                               FontSize="11"
                               Foreground="#717783"/>
                    <Button Content="&#xE8C8;" Style="{StaticResource CardActionBtn}"
                            Grid.Column="2" Grid.ColumnSpan="2"
                            HorizontalAlignment="Right" VerticalAlignment="Bottom"
                            ToolTip="Copy"
                            Click="CardCopy_Click" Tag="{Binding}"/>
                    <Button Content="&#xE718;" Style="{StaticResource CardActionBtn}"
                            Grid.Column="2" Grid.ColumnSpan="2"
                            HorizontalAlignment="Right" VerticalAlignment="Bottom"
                            Margin="0,0,24,0"
                            ToolTip="Pin"
                            Click="CardPin_Click" Tag="{Binding}"/>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Border BorderBrush="#C0C7D4" BorderThickness="1" CornerRadius="8" Background="#FCF9F8" ClipToBounds="True">
    <Grid Background="#FCF9F8">
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- =============================== -->
        <!-- CUSTOM TITLE BAR               -->
        <!-- =============================== -->
        <Border Grid.Row="0" Background="#F6F3F2" BorderBrush="#E5E2E1" BorderThickness="0,0,0,1"
                MouseDown="TitleBar_MouseDown">
            <Grid>
                <TextBlock Text="OmniClip" FontSize="12" FontWeight="SemiBold" Foreground="#404752"
                           VerticalAlignment="Center" Margin="12,0,0,0"/>
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" VerticalAlignment="Stretch">
                    <Button x:Name="MinimizeBtn" Content="&#xE921;" FontFamily="Segoe MDL2 Assets"
                            FontSize="10" Foreground="#404752"
                            Width="46" Height="32" Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Click="MinimizeBtn_Click"/>
                    <Button x:Name="MaximizeBtn" Content="&#xE922;" FontFamily="Segoe MDL2 Assets"
                            FontSize="10" Foreground="#404752"
                            Width="46" Height="32" Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Click="MaximizeBtn_Click"/>
                    <Button x:Name="CloseBtn" Content="&#xE8BB;" FontFamily="Segoe MDL2 Assets"
                            FontSize="10" Foreground="#404752"
                            Width="46" Height="32" Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Click="CloseBtn_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="228"/>
            <ColumnDefinition Width="384"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left navigation: matches screen.png proportions and spacing -->
        <Border Grid.Column="0" Background="#F6F3F2" BorderBrush="#E5E2E1" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="20,28,20,36">
                    <svgc:SvgViewbox Source="pack://application:,,,/Resources/logo.svg"
                                     Width="40" Height="40"
                                     Margin="0,0,14,0"
                                     VerticalAlignment="Center"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="OmniClip" FontSize="22" FontWeight="SemiBold" Foreground="#005FAA"/>
                        <TextBlock Text="Professional Clipboard" Margin="0,4,0,0" FontSize="12" Foreground="#404752"/>
                    </StackPanel>
                </StackPanel>

                <ListBox Grid.Row="1" x:Name="SidebarNav"
                         BorderThickness="0"
                         Background="Transparent"
                         SelectionChanged="SidebarNav_SelectionChanged">
                    <ListBoxItem Style="{StaticResource NavItem}" IsSelected="True" Tag="all">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource IconText}" Text="&#xE81C;" Width="24"/>
                            <TextBlock Text="All Items" FontSize="14" Margin="16,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Style="{StaticResource NavItem}" Tag="code">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource IconText}" Text="&#xE943;" Width="24"/>
                            <TextBlock Text="Code Snippets" FontSize="15" Margin="16,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Style="{StaticResource NavItem}" Tag="url">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource IconText}" Text="&#xE71B;" Width="24"/>
                            <TextBlock Text="Web Links" FontSize="15" Margin="16,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Style="{StaticResource NavItem}" Tag="text">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource IconText}" Text="&#xE8A5;" Width="24"/>
                            <TextBlock Text="Plain Text" FontSize="15" Margin="16,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Style="{StaticResource NavItem}" Tag="image">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource IconText}" Text="&#xE91B;" Width="24"/>
                            <TextBlock Text="Images" FontSize="15" Margin="16,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Style="{StaticResource NavItem}" Tag="file">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource IconText}" Text="&#xE723;" Width="24"/>
                            <TextBlock Text="Files" FontSize="15" Margin="16,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListBoxItem>
                </ListBox>

                <Border Grid.Row="2"
                        Height="40"
                        Margin="20,0,20,16"
                        Background="#E9E9EA"
                        CornerRadius="7"
                        Cursor="Hand"
                        MouseDown="AiInsights_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="✦" FontSize="18" Foreground="#5F6161" Margin="0,0,8,0"/>
                        <TextBlock Text="AI Insights" FontSize="13" FontWeight="SemiBold" Foreground="#5F6161"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="3" Margin="20,0,20,20" BorderBrush="#E5E2E1" BorderThickness="0,1,0,0" Padding="0,14,0,0">
                    <Button x:Name="SettingsBtn"
                            Background="Transparent" BorderThickness="0" Foreground="#202734"
                            Cursor="Hand" HorizontalContentAlignment="Left"
                            Click="Settings_Click"
                            MouseEnter="SettingsBtn_MouseEnter"
                            MouseLeave="SettingsBtn_MouseLeave">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="{TemplateBinding Background}"
                                        BorderThickness="0" CornerRadius="7" Height="44">
                                    <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"
                                                      Margin="20,0"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal" x:Name="SettingsPanel"
                                    RenderTransformOrigin="0,0.5">
                            <StackPanel.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </StackPanel.RenderTransform>
                            <TextBlock Style="{StaticResource IconText}" Text="&#xE713;" Width="24" FontSize="21"/>
                            <TextBlock Text="Settings" FontSize="14" Margin="16,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Border>
            </Grid>
        </Border>

        <!-- Clipboard feed -->
        <Border Grid.Column="1" Background="#FCF9F8" BorderBrush="#E5E2E1" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="24,16,24,18" BorderBrush="#F0EDED" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <Border Height="36" Background="#F6F3F2" CornerRadius="18" Padding="14,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="#7A808A" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <Grid Grid.Column="1">
                                    <TextBox x:Name="MainSearchBox"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             FontSize="14"
                                             Foreground="#1B1B1B"
                                             VerticalContentAlignment="Center"
                                             CaretBrush="#005FAA"
                                             TextChanged="MainSearchBox_TextChanged"/>
                                    <TextBlock Text="Search clipboard"
                                               FontSize="14" Foreground="#A0A7B4"
                                               VerticalAlignment="Center"
                                               IsHitTestVisible="False"
                                               Margin="1,0,0,0"
                                               Visibility="Visible"
                                               x:Name="SearchPlaceholder"/>
                                </Grid>
                            </Grid>
                        </Border>

                        <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                            <Button x:Name="AllChip" Content="All Types" Style="{StaticResource PillButton}" Margin="0,0,10,0" Click="FilterChip_Click"/>
                            <Button x:Name="UnpinnedChip" Content="Pinned" Style="{StaticResource PillButton}" Background="#FCF9F8" Foreground="#202734" Click="FilterChip_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <ListBox Grid.Row="1" x:Name="EntryListMain"
                         Margin="0"
                         Padding="16,0,16,24"
                         BorderThickness="0"
                         Background="Transparent"
                         SelectionChanged="EntryListMain_SelectionChanged"
                         ScrollViewer.VerticalScrollBarVisibility="Hidden"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.CanContentScroll="True"
                         VirtualizingStackPanel.IsVirtualizing="True"
                         VirtualizingStackPanel.ScrollUnit="Pixel"/>
            </Grid>
        </Border>

        <!-- Preview pane -->
        <Border Grid.Column="2" Background="#F2EFEE">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="32,28,32,28">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,20,0">
                        <Border Width="40" Height="40" CornerRadius="20" Background="#0078D4" Margin="0,0,16,0">
                            <TextBlock x:Name="PreviewIcon" Text="&#xE943;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel>
                            <TextBlock x:Name="PreviewTitle" Text="Code Snippet" FontSize="24" FontWeight="SemiBold" Foreground="#000000" TextTrimming="CharacterEllipsis"/>
                            <TextBlock x:Name="PreviewMeta" Text="Copied from VS Code · Today, 10:42 AM · 1.2 KB"
                                       FontSize="13" Foreground="#404752"
                                       TextWrapping="Wrap" MaxHeight="36"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                        <Button Style="{StaticResource SecondaryActionButton}" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE72D;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Share" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="CopyBtn" Style="{StaticResource PrimaryActionButton}" Click="CopyEntry_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Copy to&#x0a;Clipboard" TextAlignment="Center" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <Border x:Name="PreviewCard"
                        Grid.Row="1"
                        Margin="32,0,32,32"
                        Background="#FDFCFB"
                        CornerRadius="10"
                        BorderBrush="#E5E2E1"
                        BorderThickness="1"
                        Effect="{StaticResource PreviewShadow}"
                        RenderTransformOrigin="0.5,0.5"
                        Cursor="Hand"
                        MouseEnter="PreviewCard_MouseEnter"
                        MouseLeave="PreviewCard_MouseLeave"
                        MouseDown="PreviewCard_MouseDown">
                    <Border.RenderTransform>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                    </Border.RenderTransform>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="44"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="#F6F3F2" BorderBrush="#E5E2E1" BorderThickness="0,0,0,1" CornerRadius="10,10,0,0" Padding="16,0">
                            <Grid>
                                <TextBlock x:Name="PreviewLangLabel" Text="javascript" FontSize="13" Foreground="#202734" VerticalAlignment="Center"/>
                                <Button Content="&#xE8A7;" FontFamily="Segoe MDL2 Assets"
                                        FontSize="16" Foreground="#717783"
                                        Width="32" Height="32" Background="Transparent"
                                        BorderThickness="0" Cursor="Hand"
                                        HorizontalAlignment="Right" VerticalAlignment="Center"
                                        Click="OpenInApp_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" Background="Transparent" CornerRadius="6">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#EAE7E7"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </Border>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="26,26,26,26">
                            <Grid>
                                <TextBox x:Name="PreviewText"
                                         Text="Select a clipboard item to preview its content here."
                                         FontSize="14"
                                         Foreground="#202734"
                                         TextWrapping="Wrap"
                                         IsReadOnly="True"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Visibility="Visible"/>
                                <Image x:Name="PreviewImage"
                                       Stretch="Uniform"
                                       StretchDirection="DownOnly"
                                       HorizontalAlignment="Stretch"
                                       VerticalAlignment="Stretch"
                                       Visibility="Collapsed"/>
                            </Grid>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Border>
        </Grid>
    </Grid>
    </Border>
</Window>
