<Window x:Class="OmniClip.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:OmniClip.App.Converters"
        Title="OmniClip"
        Width="1020" Height="640"
        MinWidth="800" MinHeight="500"
        Background="#FCF9F8"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True">

    <Window.Resources>
        <conv:RelativeTimeConverter x:Key="RelTime"/>
        <conv:ContentTypeToColorConverter x:Key="TypeToColor"/>
        <conv:ContentTypeToIconConverter x:Key="TypeToIcon"/>

        <!-- Colors -->
        <SolidColorBrush x:Key="SurfaceLow" Color="#F6F3F2"/>
        <SolidColorBrush x:Key="OutlineVariant" Color="#C0C7D4"/>
        <SolidColorBrush x:Key="Primary" Color="#005FAA"/>
        <SolidColorBrush x:Key="PrimaryContainer" Color="#0078D4"/>
        <SolidColorBrush x:Key="PrimaryFixed" Color="#D3E3FF"/>
        <SolidColorBrush x:Key="OnSurface" Color="#1B1B1B"/>
        <SolidColorBrush x:Key="OnSurfaceVariant" Color="#404752"/>
        <SolidColorBrush x:Key="Secondary" Color="#5D5F5F"/>
        <SolidColorBrush x:Key="Tertiary" Color="#974700"/>

        <!-- Sidebar nav item style -->
        <Style x:Key="NavItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="8,1"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="256"/>
            <ColumnDefinition Width="384"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ========== COLUMN 1: SIDEBAR ========== -->
        <Border Grid.Column="0" Background="#F6F3F2" BorderBrush="#E5E2E1" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" Margin="16,20,16,16">
                    <TextBlock Text="OmniClip" FontSize="20" FontWeight="SemiBold"
                               Foreground="#005FAA"/>
                    <TextBlock Text="Professional Clipboard" FontSize="11"
                               Foreground="#717783" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Nav items -->
                <ListBox Grid.Row="1" x:Name="SidebarNav" BorderThickness="0"
                         Background="Transparent"
                         SelectionChanged="SidebarNav_SelectionChanged">
                    <ListBoxItem Style="{StaticResource NavItem}" IsSelected="True" Tag="all">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE81C;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="All Items" FontSize="14" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Style="{StaticResource NavItem}" Tag="code">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE943;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Code Snippets" FontSize="14" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Style="{StaticResource NavItem}" Tag="url">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE71B;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Web Links" FontSize="14" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Style="{StaticResource NavItem}" Tag="text">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Plain Text" FontSize="14" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Style="{StaticResource NavItem}" Tag="image">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE722;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Images" FontSize="14" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Style="{StaticResource NavItem}" Tag="file">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xED25;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Files" FontSize="14" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListBoxItem>
                </ListBox>

                <!-- Settings button -->
                <Button Grid.Row="2" Margin="16,0,16,12" Padding="12,8"
                        Background="Transparent" BorderThickness="0"
                        Foreground="#404752" FontSize="14" Cursor="Hand"
                        Click="Settings_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="16" Margin="0,0,12,0"/>
                        <TextBlock Text="Settings" FontSize="14"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ========== COLUMN 2: FEED ========== -->
        <Grid Grid.Column="1" Background="White">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Search header -->
            <Border Grid.Row="0" Padding="24,16" Background="White"
                    BorderBrush="#E5E2E1" BorderThickness="0,0,0,1">
                <StackPanel>
                    <!-- Search bar -->
                    <Border Background="#F6F3F2" CornerRadius="20"
                            BorderBrush="#C0C7D4" BorderThickness="0.5"
                            Padding="10,8" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="&#xE721;"
                                       FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       Foreground="#717783" VerticalAlignment="Center"
                                       Margin="4,0,8,0"/>
                            <TextBox Grid.Column="1" x:Name="MainSearchBox"
                                     Background="Transparent" Foreground="#1B1B1B"
                                     BorderThickness="0" FontSize="13"
                                     VerticalAlignment="Center"
                                     CaretBrush="#005FAA"
                                     TextChanged="MainSearchBox_TextChanged"/>
                        </Grid>
                    </Border>

                    <!-- Filter chips -->
                    <StackPanel Orientation="Horizontal">
                        <Button Content="All Types" Margin="0,0,8,0"
                                Padding="12,6" FontSize="12" FontWeight="SemiBold"
                                Background="#F0EDED" Foreground="#1B1B1B"
                                BorderBrush="#C0C7D4" BorderThickness="0.5" Cursor="Hand"
                                Click="FilterChip_Click"/>
                        <Button Content="Unpinned"
                                Padding="12,6" FontSize="12" FontWeight="SemiBold"
                                Background="#F0EDED" Foreground="#1B1B1B"
                                BorderBrush="#C0C7D4" BorderThickness="0.5" Cursor="Hand"
                                Click="FilterChip_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Feed list -->
            <ListBox Grid.Row="1" x:Name="EntryListMain" BorderThickness="0"
                     Background="Transparent"
                     SelectionChanged="EntryListMain_SelectionChanged"
                     ScrollViewer.VerticalScrollBarVisibility="Hidden"
                     Margin="8,12,8,8">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0,0,0,8"/>
                        <Setter Property="Background" Value="#FCF9F8"/>
                        <Setter Property="BorderBrush" Value="#C0C7D4"/>
                        <Setter Property="BorderThickness" Value="1"/>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="12" Background="{Binding Background,
                            RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                BorderBrush="{Binding BorderBrush,
                            RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                BorderThickness="1" CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Type indicator strip -->
                                <Border Grid.Column="0" CornerRadius="0,2,2,0" Width="3"
                                        VerticalAlignment="Stretch"
                                        Background="{Binding ContentType,
                                            Converter={StaticResource TypeToColor}}"/>

                                <!-- Icon -->
                                <TextBlock Grid.Column="1"
                                           FontFamily="Segoe MDL2 Assets" FontSize="18"
                                           VerticalAlignment="Top" Margin="8,2,12,0"
                                           Foreground="{Binding ContentType,
                                               Converter={StaticResource TypeToColor}}"
                                           Text="{Binding ContentType,
                                               Converter={StaticResource TypeToIcon}}"/>

                                <!-- Content -->
                                <StackPanel Grid.Column="2">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock Text="{Binding SourceApp}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="#1B1B1B"/>
                                        <TextBlock Text=" · " FontSize="12" Foreground="#C0C7D4"/>
                                        <TextBlock Text="{Binding CreatedAt,
                                                   Converter={StaticResource RelTime}}"
                                                   FontSize="11" Foreground="#717783"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding PlainText}" FontSize="13"
                                               Foreground="#404752"
                                               TextTrimming="CharacterEllipsis"
                                               MaxHeight="36" TextWrapping="NoWrap"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <!-- ========== COLUMN 3: PREVIEW ========== -->
        <Border Grid.Column="2" Background="#F6F3F2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Preview header -->
                <Border Grid.Row="0" Padding="32,24"
                        BorderBrush="#E5E2E1" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Width="40" Height="40" CornerRadius="20"
                                    Background="#0078D4" Margin="0,0,16,0">
                                <TextBlock x:Name="PreviewIcon" Text="&#xE8A5;"
                                           FontFamily="Segoe MDL2 Assets" FontSize="18"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel>
                                <TextBlock x:Name="PreviewTitle" Text="Select an item"
                                           FontSize="20" FontWeight="SemiBold"
                                           Foreground="#1B1B1B"/>
                                <TextBlock x:Name="PreviewMeta" Text=""
                                           FontSize="11" Foreground="#717783" Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="56,0,0,0">
                            <Button x:Name="CopyBtn" Content="Copy to Clipboard"
                                    Click="CopyEntry_Click"
                                    Background="#005FAA" Foreground="White"
                                    BorderThickness="0" FontSize="12" FontWeight="SemiBold"
                                    Padding="14,8" Margin="0,0,8,0" Cursor="Hand"/>
                            <Button x:Name="DeleteBtn" Content="Delete"
                                    Click="DeleteEntry_Click"
                                    Background="Transparent" Foreground="#404752"
                                    BorderBrush="#C0C7D4" BorderThickness="1"
                                    FontSize="12" FontWeight="SemiBold"
                                    Padding="14,8" Cursor="Hand"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Preview content -->
                <Border Grid.Row="1" Margin="32,24,32,32"
                        Background="White" CornerRadius="8"
                        BorderBrush="#C0C7D4" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="#F6F3F2"
                                BorderBrush="#E5E2E1" BorderThickness="0,0,0,1"
                                Padding="16,8">
                            <TextBlock x:Name="PreviewLangLabel" Text="text"
                                       FontSize="11" Foreground="#717783"
                                       FontWeight="SemiBold"/>
                        </Border>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden"
                                      Padding="20">
                            <TextBlock x:Name="PreviewText"
                                       Text="Select a clipboard item to preview"
                                       FontSize="14" Foreground="#404752"
                                       TextWrapping="Wrap" LineHeight="22"/>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
