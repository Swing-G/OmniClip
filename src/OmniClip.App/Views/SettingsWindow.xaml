<Window x:Class="OmniClip.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Settings"
        Width="560" Height="620"
        MinWidth="480" MinHeight="560"
        ResizeMode="NoResize"
        Background="#FCF9F8"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="False">

    <WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" CornerRadius="8"
                            GlassFrameThickness="0" ResizeBorderThickness="4"
                            UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#F6F3F2"/>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#005FAA"/>
        <SolidColorBrush x:Key="OutlineBrush" Color="#D9DEE7"/>
        <SolidColorBrush x:Key="OnSurfaceBrush" Color="#1B1B1B"/>
        <SolidColorBrush x:Key="OnSurfaceVariantBrush" Color="#404752"/>
        <SolidColorBrush x:Key="LabelBrush" Color="#5D5F5F"/>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#005FAA"/>
            <Setter Property="Margin" Value="0,24,0,12"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#404752"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Width" Value="130"/>
        </Style>

        <Style x:Key="FieldInput" TargetType="TextBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#1B1B1B"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D9DEE7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="#005FAA"/>
        </Style>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinWidth" Value="80"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Background" Value="#005FAA"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0060AB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#1B1B1B"/>
            <Setter Property="BorderBrush" Value="#D9DEE7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F6F3F2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CheckBoxStyle" TargetType="CheckBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#1B1B1B"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="NumInput" TargetType="TextBox" BasedOn="{StaticResource FieldInput}">
            <Setter Property="Width" Value="100"/>
            <Setter Property="TextAlignment" Value="Right"/>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#C0C7D4" BorderThickness="1" CornerRadius="8" Background="#FCF9F8" ClipToBounds="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title bar matching main window style -->
        <Border Grid.Row="0" Background="#F6F3F2" BorderBrush="#E5E2E1" BorderThickness="0,0,0,1"
                MouseDown="TitleBar_MouseDown">
            <Grid>
                <TextBlock Text="Settings" FontSize="12" FontWeight="SemiBold" Foreground="#404752"
                           VerticalAlignment="Center" Margin="12,0,0,0"/>
                <Button Content="&#xE8BB;" FontFamily="Segoe MDL2 Assets"
                        FontSize="10" Foreground="#404752"
                        Width="46" Height="32" Background="Transparent" BorderThickness="0" Cursor="Hand"
                        HorizontalAlignment="Right" Click="CloseBtn_Click"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="40,28,40,28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Preferences" FontSize="22" FontWeight="SemiBold"
                       Foreground="#000000" Margin="0,0,0,8"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden" Margin="0,8,0,0">
            <StackPanel>

                <!-- ── Storage ── -->
                <TextBlock Style="{StaticResource SectionTitle}" Text="Storage"/>
                <StackPanel Margin="0,0,0,6">
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Data path" Grid.Column="0"/>
                        <Grid Grid.Column="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="StoragePathInput" Style="{StaticResource FieldInput}" Grid.Column="0"
                                     Margin="0,0,6,0"/>
                            <Button Grid.Column="1" Content="Browse" Style="{StaticResource SecondaryBtn}"
                                    Width="70" Click="BrowsePath_Click"/>
                        </Grid>
                    </Grid>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Retention" Grid.Column="0"/>
                        <TextBox x:Name="RetentionInput" Style="{StaticResource NumInput}" Grid.Column="1"/>
                        <TextBlock Text=" days" FontSize="13" Foreground="#5D5F5F" VerticalAlignment="Center"
                                   Grid.Column="2" Margin="6,0,0,0"/>
                    </Grid>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Max storage" Grid.Column="0"/>
                        <TextBox x:Name="MaxStorageInput" Style="{StaticResource NumInput}" Grid.Column="1"/>
                        <TextBlock Text=" MB" FontSize="13" Foreground="#5D5F5F" VerticalAlignment="Center"
                                   Grid.Column="2" Margin="6,0,0,0"/>
                    </Grid>
                </StackPanel>

                <!-- ── Capture ── -->
                <TextBlock Style="{StaticResource SectionTitle}" Text="Capture"/>
                <StackPanel Margin="0,0,0,6">
                    <WrapPanel Margin="0,0,0,10">
                        <CheckBox x:Name="CaptureTextChk" Content="Text" Style="{StaticResource CheckBoxStyle}"
                                  Margin="0,0,20,4"/>
                        <CheckBox x:Name="CaptureImageChk" Content="Image" Style="{StaticResource CheckBoxStyle}"
                                  Margin="0,0,20,4"/>
                        <CheckBox x:Name="CaptureFileChk" Content="File" Style="{StaticResource CheckBoxStyle}"
                                  Margin="0,0,20,4"/>
                    </WrapPanel>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Text max length" Grid.Column="0"/>
                        <TextBox x:Name="MaxTextInput" Style="{StaticResource NumInput}" Grid.Column="1"/>
                        <TextBlock Text=" KB" FontSize="13" Foreground="#5D5F5F" VerticalAlignment="Center"
                                   Grid.Column="2" Margin="6,0,0,0"/>
                    </Grid>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Min text length" Grid.Column="0"/>
                        <TextBox x:Name="MinTextInput" Style="{StaticResource NumInput}" Grid.Column="1"/>
                        <TextBlock Text=" chars" FontSize="13" Foreground="#5D5F5F" VerticalAlignment="Center"
                                   Grid.Column="2" Margin="6,0,0,0"/>
                    </Grid>
                </StackPanel>

                <!-- ── File Limits ── -->
                <TextBlock Style="{StaticResource SectionTitle}" Text="File limits"/>
                <StackPanel Margin="0,0,0,6">
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Max file size" Grid.Column="0"/>
                        <TextBox x:Name="MaxFileInput" Style="{StaticResource NumInput}" Grid.Column="1"/>
                        <TextBlock Text=" MB" FontSize="13" Foreground="#5D5F5F" VerticalAlignment="Center"
                                   Grid.Column="2" Margin="6,0,0,0"/>
                    </Grid>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Image resize" Grid.Column="0"/>
                        <TextBox x:Name="ImageMaxWInput" Style="{StaticResource NumInput}" Width="72" Grid.Column="1"/>
                        <TextBlock Text="×" FontSize="13" Foreground="#5D5F5F" VerticalAlignment="Center"
                                   HorizontalAlignment="Center" Grid.Column="2"/>
                        <TextBox x:Name="ImageMaxHInput" Style="{StaticResource NumInput}" Width="72" Grid.Column="3"/>
                    </Grid>
                </StackPanel>

                <!-- ── Monitor ── -->
                <TextBlock Style="{StaticResource SectionTitle}" Text="Monitor"/>
                <StackPanel Margin="0,0,0,6">
                    <CheckBox x:Name="MonitorChk" Content="Enable clipboard monitoring"
                              Style="{StaticResource CheckBoxStyle}" Margin="0,0,0,10"/>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Hotkey" Grid.Column="0"/>
                        <TextBox x:Name="HotkeyInput" Style="{StaticResource FieldInput}" Grid.Column="1"/>
                    </Grid>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Excluded apps" Grid.Column="0"/>
                        <TextBox x:Name="ExcludedAppsInput" Style="{StaticResource FieldInput}" Grid.Column="1"
                                 TextWrapping="Wrap" AcceptsReturn="True" Height="56"
                                 ToolTip="One app name per line. Content from these apps will not be stored."/>
                    </Grid>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- ── Bottom Buttons ── -->
        <Grid Grid.Row="2" Margin="0,20,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Content="Restore defaults" Style="{StaticResource SecondaryBtn}"
                        Click="RestoreDefaults_Click"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Style="{StaticResource SecondaryBtn}" Margin="0,0,8,0"
                        Click="Cancel_Click"/>
                <Button Content="Save" Style="{StaticResource PrimaryBtn}"
                        Click="Save_Click"/>
            </StackPanel>
            </Grid>
        </Grid>
    </Grid>
    </Border>
</Window>
