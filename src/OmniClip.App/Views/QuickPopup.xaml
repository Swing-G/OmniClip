<Window x:Class="OmniClip.App.Views.QuickPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:OmniClip.App.Converters"
        Title="OmniClip"
        Width="360" Height="420"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        FontFamily="Segoe UI"
        Deactivated="Window_Deactivated">

    <Window.Resources>
        <conv:RelativeTimeConverter x:Key="RelTime"/>
        <conv:ContentTypeToColorConverter x:Key="TypeToColor"/>
        <conv:ContentTypeToIconConverter x:Key="TypeToIcon"/>

        <Style x:Key="PopupCardItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="CardBorder" Padding="12,10"
                                Margin="0,0,0,4"
                                Background="#FCF9F8"
                                BorderBrush="#C0C7D4"
                                BorderThickness="0.5"
                                CornerRadius="8"
                                Cursor="Hand">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CardBorder" Property="Background" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="CardBorder" Property="Background" Value="#D3E3FF"/>
                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="#005FAA"/>
                                <Setter TargetName="CardBorder" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="White" CornerRadius="8" BorderBrush="#C0C7D4" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.1" BlurRadius="16" ShadowDepth="4"/>
        </Border.Effect>

        <DockPanel>
            <!-- Search bar -->
            <Border DockPanel.Dock="Top" Padding="12,10" Background="White"
                    BorderBrush="#E5E2E1" BorderThickness="0,0,0,1">
                <Border Background="#F6F3F2" CornerRadius="20"
                        BorderBrush="#C0C7D4" BorderThickness="0.5"
                        Padding="10,7">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#xE721;"
                                   FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   Foreground="#717783" VerticalAlignment="Center"
                                   Margin="4,0,8,0"/>
                        <TextBox Grid.Column="1" x:Name="SearchBox"
                                 Background="Transparent" Foreground="#1B1B1B"
                                 BorderThickness="0" FontSize="13"
                                 VerticalAlignment="Center"
                                 CaretBrush="#005FAA"
                                 TextChanged="SearchBox_TextChanged"/>
                    </Grid>
                </Border>
            </Border>

            <!-- Entry list -->
            <ListBox x:Name="EntryList"
                     DockPanel.Dock="Top"
                     Background="#FCF9F8"
                     BorderThickness="0"
                     ItemContainerStyle="{StaticResource PopupCardItem}"
                     ScrollViewer.VerticalScrollBarVisibility="Hidden"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     SelectionChanged="EntryList_SelectionChanged"
                     KeyDown="EntryList_KeyDown"
                     Padding="8,8,8,0"
                     Margin="0">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <!-- Source + timestamp -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="{Binding SourceApp}"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="#1B1B1B"/>
                                <TextBlock Text=" · " FontSize="12" Foreground="#C0C7D4"/>
                                <TextBlock Text="{Binding CreatedAt, Converter={StaticResource RelTime}}"
                                           FontSize="11" Foreground="#717783"/>
                            </StackPanel>
                            <!-- Preview -->
                            <TextBlock Text="{Binding PlainText}"
                                       FontSize="13" Foreground="#404752"
                                       TextTrimming="CharacterEllipsis"
                                       MaxHeight="36" TextWrapping="NoWrap"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Bottom hints bar -->
            <Border DockPanel.Dock="Bottom" Padding="10,6" Background="#F6F3F2"
                    BorderBrush="#E5E2E1" BorderThickness="0,1,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="↑↓ Select  " FontSize="10" Foreground="#C0C7D4"/>
                    <TextBlock Text="Enter Paste  " FontSize="10" Foreground="#C0C7D4"/>
                    <TextBlock Text="Esc Dismiss" FontSize="10" Foreground="#C0C7D4"/>
                </StackPanel>
            </Border>
        </DockPanel>
    </Border>
</Window>
