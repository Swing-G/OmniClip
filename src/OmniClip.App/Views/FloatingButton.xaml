<Window x:Class="OmniClip.App.Views.FloatingButton"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title=""
        Width="48" Height="48"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        MouseDown="Window_MouseDown">

    <Grid>
        <Border Background="#005FAA" CornerRadius="24" Cursor="Hand"
                MouseDown="Button_MouseDown"
                Opacity="0.85"
                Width="44" Height="44">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" ShadowDepth="4" Opacity="0.3" Color="#000000"/>
            </Border.Effect>
            <TextBlock Text="&#xE81C;" FontFamily="Segoe MDL2 Assets"
                       FontSize="20" Foreground="White"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
        <!-- Close X -->
        <Border Background="#FF4444" CornerRadius="9" Width="18" Height="18"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,-2,-2,0"
                Cursor="Hand"
                Opacity="0"
                x:Name="CloseBtn"
                MouseDown="CloseBtn_MouseDown">
            <TextBlock Text="&#xE106;" FontFamily="Segoe MDL2 Assets"
                       FontSize="8" Foreground="White"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
